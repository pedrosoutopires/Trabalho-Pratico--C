#include <stdio.h>
#include <string.h>

void opcao1(char nome[][50], char email[][30], float salario[],
            int *contador, int *repeticao, int *contador2)
{
    int i, j;

    do{
        printf("ME INFORME QUANTOS CADASTROS VOCE QUER ENTRE 1 E 10: ");
        scanf("%d%*c", repeticao);
        *contador2 = *contador + *repeticao;
    }while(*contador2 < 1 || *contador2 > 10);

    for(i = *contador; i < *contador2; i++) {

        printf("--- CADASTRO %d/10 ---\n", i + 1);

        printf("ME INFORME O SEU NOME: ");
        fgets(nome[i], 50, stdin);

        for(j = 0; nome[i][j] != '\0'; j++) {
            if(nome[i][j] == '\n') {
                nome[i][j] = '\0';
                break;
            }
        }

        printf("%s, ME INFORME AGORA O SEU EMAIL: ", nome[i]);

        fgets(email[i], 30, stdin);

        for(j = 0; email[i][j] != '\0'; j++) {
            if(email[i][j] == '\n') {
                email[i][j] = '\0';
                break;
            }
        }

        printf("%s, ME INFORME SEU SALARIO: ", nome[i]);
        scanf("%f%*c", &salario[i]);

        (*contador)++;

        printf("\n");
    }

    if(*contador2 == 10)
        printf("\nAGENDA CHEIA\n");
}

void opcao2(char nome[][50], char email[][30], float salario[],
            int contador, int repeticao, int contador2)
{
    int i;

    if(contador + repeticao > 0) {

        for(i = 0; i < contador2; i++) {

            printf("--- DADOS %d/10 ---\n", i + 1);
            printf("NOME: %s\n", nome[i]);
            printf("EMAIL: %s\n", email[i]);
            printf("SALARIO: %.2f\n", salario[i]);
            printf("\n");

        }

    }
}

void opcao3(char nome[][50], char email[][30], float salario[], int contador){

    int i;
    char busca[50];

    if(contador == 0){
        printf("Nenhum funcionario cadastrado.\n");
        return;
    }

    printf("Digite o nome do funcionario: ");
    scanf(" %49[^\n]", busca);

    for(i = 0; i < contador; i++){
        if(strcmp(nome[i], busca) == 0){
            printf("\nNOME: %s\n", nome[i]);
            printf("EMAIL: %s\n", email[i]);
            printf("SALARIO: %.2f\n", salario[i]);
            return;
        }
    }

    printf("Funcionario nao encontrado.\n");
}

void opcao4(char nome[][50], float salario[], int contador){

    int i, indiceMaior = 0;

    if(contador == 0){
        printf("Nenhum funcionario cadastrado.\n");
        return;
    }

    for(i = 1; i < contador; i++){
        if(salario[i] > salario[indiceMaior]){
            indiceMaior = i;
        }
    }

    printf("\nFuncionario com maior salario:\n");
    printf("NOME: %s\n", nome[indiceMaior]);
    printf("SALARIO: %.2f\n", salario[indiceMaior]);
}

void opcao5(float salario[], int contador){

    int i;
    float soma = 0;

    if(contador == 0){
        printf("Nenhum funcionario cadastrado.\n");
        return;
    }

    for(i = 0; i < contador; i++){
        soma += salario[i];
    }

    printf("\nMedia salarial: %.2f\n", soma / contador);
}

int main() {
    int i, j, opcao, cheio = 0, contador = 0, repeticao = 0, contador2 = 0;
    char nome[10][50], email[10][30];
    float salario[10];

    do {

        do {
            printf("\tMENU DE OPCOES\t\n");
            printf("1.CADASTRAR NOVO FUNCIONARIO\n");
            printf("2.MOSTRAR TODOS OS DADOS\n");
            printf("3.BUSCAR DADOS DE UMA PESSOA\n");
            printf("4.MOSTRAR MAIOR SALARIO\n");
            printf("5.MOSTRAR MEDIA SALARIAL\n");
            printf("6.SAIR\n");
            printf("Escolha uma opcao: ");
            scanf("%d%*c", &opcao);
            printf("\n");
        } while(opcao < 1 || opcao > 6);

        if(opcao == 1) {
            opcao1(nome, email, salario, &contador, &repeticao, &contador2);
        }

        if(opcao == 2) {
            opcao2(nome, email, salario, contador, repeticao, contador2);
        }

        if(opcao == 3){
            opcao3(nome, email, salario, contador);
        }

        if(opcao == 4){
            opcao4(nome, salario, contador);
        }

        if(opcao == 5){
            opcao5(salario, contador);
        }

        } while(opcao != 6);

    printf("Programa finalizado. Ate logo!\n");

    return 0;
}
